# ==============================================
#  GOATCINE — Variáveis de Ambiente
#  RENOMEIE ESTE ARQUIVO PARA: .env
# ==============================================

# ---- Servidor ----
PORT=3000

# ---- JWT Secret (mude para uma string aleatória longa e secreta!) ----
JWT_SECRET=goatcine_super_secret_jwt_key_mude_isso_em_producao_2024

# ---- Discord OAuth2 ----
# Crie seu app em: https://discord.com/developers/applications
# 1. Clique em "New Application", dê um nome (ex: GOATCINE)
# 2. Vá em "OAuth2" no menu lateral
# 3. Copie o "Client ID" e "Client Secret"
# 4. Em "Redirects", adicione: http://localhost:3000/auth/discord/callback
DISCORD_CLIENT_ID=1520916959661916381
DISCORD_CLIENT_SECRET=nvVgZ-QfIb9xde42kEr9xvGdJtfS6UvO
DISCORD_REDIRECT_URI=https://discord.com/oauth2/authorize?client_id=1520916959661916381&permissions=8&integration_type=0&scope=bot+applications.commands
# ---- App ----
# URL base do frontend (onde está o index.html)
FRONTEND_URL=http://localhost:3000

# ---- Nova Gateway GoatPay (PIX) ----
# Obtenha sua chave gp_live_... e segredo do webhook whsec_... no painel da GoatPay
GOATPAY_API_KEY=gp_live_7527edf0c1e885425f50a5d302c3c7b310cbcfecc3a838fa
GOATPAY_WEBHOOK_SECRET=whsec_bf051132b09d4c3aa4ed7acf830fd89dd8d084c51b7f5a87

